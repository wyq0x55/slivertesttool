# Copy to .env and adjust. All values are optional (safe defaults apply).

# --- Web server ---
HOST=0.0.0.0
PORT=8080
SECRET_KEY=change-me-internal-secret

# --- Database (PostgreSQL only) ---
# The platform runs exclusively on PostgreSQL (SQLite support has been removed).
# Standard SQLAlchemy DSN using the psycopg2 driver. The default targets a local
# PostgreSQL; change it to your LAN database server.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/silvetestapp
# Background task queue (Huey) storage. Defaults to DATABASE_URL; set this only
# to keep the queue tables in a separate database.
# HUEY_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/silvetestapp
# HUEY_NAME=silvetestapp

# --- Admin ---
# Administration is gated by the LAN Test Matrix system-admin session (RBAC);
# the former ADMIN_TOKEN has been removed. Grant a user "System Administrator"
# to authorise the admin console and the /api/admin/* + /api/v1/admin/* APIs.
# Bootstrap the first admin via LM_ADMIN_USER / LM_ADMIN_PASSWORD below.

# --- LAN Test Matrix (online editor) ---
# The lanmatrix project is expanded into app/services/lanmatrix and fully driven
# by this file. All values below are optional (safe defaults apply).
#
# Bootstrap system administrator, seeded on first start when none exists.
# Leave LM_ADMIN_PASSWORD empty to use the default 'Admin@12345' AND force a
# password change on first login; set it to disable the forced change.
# NOTE: when LM_ADMIN_PASSWORD is set, it is *reconciled* on every startup — the
# bootstrap admin's password is (re)applied and any lockout/disabled state
# cleared. So changing it here and restarting the app is enough to reset the
# admin login (an empty value never overwrites an existing password).
LM_ADMIN_USER=admin
LM_ADMIN_PASSWORD=
# Account lockout: lock for LM_LOCK_MINUTES after LM_LOCK_THRESHOLD failed logins.
LM_LOCK_THRESHOLD=5
LM_LOCK_MINUTES=15
# Server-side pagination for item/audit listings (default and hard cap).
LM_PAGE_SIZE=100
LM_PAGE_SIZE_MAX=500
# Max sample rows returned by a batch search/replace preview.
LM_BATCH_SAMPLE_LIMIT=100
# Max import-validation errors echoed back to the client.
LM_IMPORT_ERROR_LIMIT=500
# User-supplied regex guards: length cap and per-match timeout (seconds).
LM_REGEX_MAX_LEN=200
LM_REGEX_TIMEOUT=0.25
# Max length of a sanitised uploaded/exported filename base.
LM_FILENAME_MAX_LEN=120
# Test-Matrix (Excel) bridge defaults: ID column prefix and summary sheet name.
LM_TM_ID_PREFIX=ID;;
LM_TM_SUMMARY_SHEET=4.TestRequirement
# Self-service registration for LAN users (login page "注册" link).
# LM_ALLOW_REGISTRATION=1 enables it; new accounts get no project access until
# an admin assigns a role. Set default status to 'disabled' to require admin
# approval before the account can log in.
LM_ALLOW_REGISTRATION=1
LM_REGISTRATION_DEFAULT_STATUS=active
LM_PASSWORD_MIN_LEN=8
# Username whitelist pattern (must fully match).
LM_USERNAME_PATTERN=^[A-Za-z0-9_.\-]{3,64}$

# --- License / concurrency ---
# Startup default for max concurrent Silver runs (adjustable at runtime).
LICENSE_LIMIT=4
# Worker thread pool size (keep >= LICENSE_LIMIT).
HUEY_WORKERS=16

# --- Silver runner ---
# mock = simulate (no license); silver = real Synopsys Silver (needs SILVER_HOME)
RUNNER_BACKEND=mock
DEFAULT_SIL_RELPATH=model.sil
EXECUTION_TIMEOUT=5000
SILVER_GUI=0

# --- Pre-warmed Silver instance pool ---
# The worker launches LICENSE_LIMIT empty Silver instances at start-up and
# reuses them for every test (avoids the per-test Silver launch cost and
# pre-empts the licenses). Set to 0 to launch a dedicated instance per test.
SILVER_POOL_ENABLED=1
# Eagerly warm the pool on start-up (vs. lazily on first demand).
SILVER_POOL_PREWARM=1
# How often (s) the worker reconciles pool size with the live license limit.
SILVER_POOL_RECONCILE_SECONDS=5
# POOL_DIR=instance/pool

# --- Storage (defaults live under the project directory) ---
# File artefacts only; all relational data + the task queue live in PostgreSQL.
# INSTANCE_DIR=instance
# UPLOAD_DIR=uploads
# REPORT_DIR=reports
# WORKSPACE_DIR=instance/workspaces

# --- Uploads ---
MAX_UPLOAD_BYTES=536870912
